{
  "name": "scara-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for SCARA robot HMI and ESP32 firmware",
  "workspaces": [
    "hmi",
    "firmware"
  ],
  "scripts": {
    "gen": "node shared/telemetry/generate.mjs",
    "dev": "npm run dev -w hmi-ta",
    "build": "npm run build -w hmi-ta",
    "firmware:build": "npm run build -w scara-firmware",
    "firmware:upload": "npm run upload -w scara-firmware",
    "firmware:monitor": "npm run monitor -w scara-firmware"
  }
}
